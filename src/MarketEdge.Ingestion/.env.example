# SQL Server connection (Windows Auth + TrustServerCertificate, matching the API/worker).
SQL_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=MarketEdge;Trusted_Connection=yes;TrustServerCertificate=yes;

# yfinance throttle settings (carried over from the worker).
YFINANCE_BATCH_SIZE=50
YFINANCE_BATCH_DELAY=2.0
YFINANCE_MAX_RETRIES=4

# Exponential-backoff base delay (s) for per-ticker fundamentals calls that hit a Yahoo
# rate limit ("Too Many Requests") or "Invalid Crumb"; attempt N waits ~base*2**N + jitter.
YFINANCE_RETRY_BASE_DELAY=1.5

# Parallel threads inside a single yfinance batch download / market-cap chunk.
YFINANCE_THREADS=10

# Worker threads for the per-symbol fundamentals loop. Keep low (4) to stay under Yahoo's
# per-IP rate limit; set 1 for fully sequential. Optional extra pacing between tickers:
FUNDAMENTALS_THREADS=4
YFINANCE_TICKER_DELAY=0.0

# Daily-bar history window fetched per ticker (yfinance period string).
DAILY_LOOKBACK_PERIOD=1y

# Hard cap on stored history (days). Bars older than this are never staged and are
# pruned on every run, keeping a strict rolling 1-year window.
DAILY_LOOKBACK_DAYS=365

# --- Observability / logging (OpenTelemetry -> NDJSON files) ---
# Log directory override (defaults: Linux /var/log/marketedge, Windows C:\ProgramData\MarketEdge\logs)
# MARKETEDGE_LOG_DIR=
MARKETEDGE_LOG_RETENTION_DAYS=7
# MARKETEDGE_ENVIRONMENT=local
# OTEL_LOG_LEVEL=INFO
