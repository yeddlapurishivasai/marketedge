AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
SQL_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=MarketEdge;Trusted_Connection=yes;TrustServerCertificate=yes;
QUEUE_NAME=stage-analysis-jobs
QUEUE_POLL_INTERVAL=10
YFINANCE_BATCH_SIZE=50
YFINANCE_BATCH_DELAY=2.0
YFINANCE_MAX_RETRIES=3

# --- Observability / logging (OpenTelemetry -> NDJSON files) ---
# Log directory override (defaults: Linux /var/log/marketedge, Windows C:\ProgramData\MarketEdge\logs)
# MARKETEDGE_LOG_DIR=
MARKETEDGE_LOG_RETENTION_DAYS=7
# MARKETEDGE_ENVIRONMENT=local
# OTEL_LOG_LEVEL=INFO
