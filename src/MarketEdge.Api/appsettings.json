{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MarketEdge": "Server=localhost;Database=MarketEdge;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "AzureStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "QueueName": "stage-analysis-jobs",
    "BackupContainer": "db-backups"
  },
  "AzureAd": {
    "Enabled": false,
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "REPLACE_WITH_TENANT_ID",
    "ClientId": "REPLACE_WITH_API_APP_CLIENT_ID",
    "SpaClientId": "REPLACE_WITH_SPA_APP_CLIENT_ID",
    "Scopes": "access_as_user",
    "AppRoles": "Api.Access"
  }
}
